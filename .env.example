# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# Generate JWT_SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Required ──────────────────────────────────────────────────────────────────

JWT_SECRET_KEY=CHANGE_ME_BEFORE_DEPLOYING

# Comma-separated CORS origins — set to your server's IP or domain.
# Falls back to * (allows all) if omitted, which is insecure in production.
CORS_ORIGINS=http://your-server-ip-or-domain

# Sub-path the app is mounted under (must have leading and trailing slash).
# Change this to move the entire app to a different path without touching any code.
# Example: BASE_PATH=/emr/  →  https://qam.hbox.ai/emr/
BASE_PATH=/emr/

# ── Optional overrides (Dockerfile defaults are correct for Docker) ───────────
# Only uncomment these if you need to override the container defaults.

# DB_PATH=/data/api.db
# ENCRYPTION_KEY_FILE=/data/encryption.key
# MEDICAL_DB_ROOT=/app
