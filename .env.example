# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# Generate JWT_SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_BEFORE_DEPLOYING

# ── Optional overrides ────────────────────────────────────────────────────────

# Comma-separated CORS origins (default set by compose to the nginx frontend).
# Add your real domain here if you front nginx with a reverse proxy.
# CORS_ORIGINS=https://etl.yourcompany.com

# Override DB location (default: /data/api.db inside the container volume)
# DB_PATH=/data/api.db

# Override encryption key file (auto-generated on first boot if absent)
# ENCRYPTION_KEY_FILE=/data/encryption.key
